---
import { getAbsoluteUrl } from '../shared/utils/routing';
---
<body style="visibility: hidden">
  <!-- Preloader Screen -->
  <div id="preloader" class="preloader">
    <div class="preloader-content">
      <h1 class="preloader-text">
        <span>T</span><span>R</span><span>I</span><span>D</span><span>I</span><span>B</span><span>E</span><span>S</span><span>H</span>
        <span>&nbsp;</span>
        <span>S</span><span>E</span><span>N</span>
        <span>&nbsp;</span>
        <span>-</span>
        <span>&nbsp;</span>
        <span>P</span><span>O</span><span>R</span><span>T</span><span>F</span><span>O</span><span>L</span><span>I</span><span>O</span>
      </h1>
      <div class="preloader-loading">LOADING SYSTEM...</div>
      <div class="preloader-bar">
        <div class="preloader-bar-inner"></div>
      </div>
    </div>
  </div>

  <!-- Instructions Popup -->
  <div id="instructions-popup" class="instructions-popup" style="display: none;">
    <div class="instructions-content">
      <button id="instructions-close-btn" class="instructions-close">&times;</button>
      <h2 class="instructions-title">HOW TO PLAY</h2>
      <div class="instructions-body">
        <p>1. Toggle <b>KEY CONTROLS</b> to switch between <b>MENU Ghost</b> or <b>PACMAN</b> arrow key control.</p>
        <p>2. Press <b>JUMP</b> or <b>Up Arrow</b> (⬆) to leap in Menu mode.</p>
        <p>3. Stand on floating islands and click <b>[ OPEN ]</b> to explore sections.</p>
        <p>4. On-screen buttons always move the Red Ghost.</p>
        <p>5. When Pacman <b>collides with a ghost</b>, it opens that ghost's section!</p>
      </div>
      <button id="instructions-start-btn" class="instructions-start-btn">READY!</button>
    </div>
  </div>

  <script>
    const popup = document.getElementById('instructions-popup');
    const closeBtn = document.getElementById('instructions-close-btn');
    const startBtn = document.getElementById('instructions-start-btn');

    const closePopup = () => {
      if (popup) {
        popup.classList.add('fade-out');
        setTimeout(() => popup.remove(), 400);
      }
    };

    if (closeBtn) closeBtn.addEventListener('click', closePopup);
    if (startBtn) startBtn.addEventListener('click', closePopup);

    // Keyboard & sound toggle control bindings
    (window as any).keyboardControlTarget = 'menu';
    (window as any).audioMuted = false;

    const menuToggle = document.getElementById('toggle-control-menu');
    const pacmanToggle = document.getElementById('toggle-control-pacman');
    const soundToggle = document.getElementById('toggle-sound');

    if (menuToggle && pacmanToggle) {
      menuToggle.addEventListener('click', () => {
        menuToggle.classList.add('active');
        pacmanToggle.classList.remove('active');
        (window as any).keyboardControlTarget = 'menu';
        window.dispatchEvent(new CustomEvent('keyboard-target-change', { detail: 'menu' }));
      });

      pacmanToggle.addEventListener('click', () => {
        pacmanToggle.classList.add('active');
        menuToggle.classList.remove('active');
        (window as any).keyboardControlTarget = 'pacman';
        window.dispatchEvent(new CustomEvent('keyboard-target-change', { detail: 'pacman' }));
      });
    }

    if (soundToggle) {
      soundToggle.addEventListener('click', () => {
        const isMuted = !(window as any).audioMuted;
        (window as any).audioMuted = isMuted;
        if (isMuted) {
          soundToggle.classList.remove('active');
          soundToggle.textContent = 'OFF';
        } else {
          soundToggle.classList.add('active');
          soundToggle.textContent = 'ON';
        }
      });
    }
  </script>

  <main class="grid">
    <header class="header">
      <h1>TRIDIBESH SEN - PORTFOLIO</h1>
      <a href="#" id="employer-link" style="display: none;" tabindex="-1"></a>
    </header>

    <!-- Controls Toggle Panel -->
    <div class="controls-toggle-container">
      <div class="toggle-section">
        <span class="controls-toggle-label">KEY CONTROLS</span>
        <div class="controls-toggle-buttons">
          <button id="toggle-control-menu" class="toggle-btn active">MENU</button>
          <button id="toggle-control-pacman" class="toggle-btn">PACMAN</button>
        </div>
      </div>
      <div class="toggle-section sound-section">
        <span class="controls-toggle-label">SOUND</span>
        <button id="toggle-sound" class="toggle-btn active">ON</button>
      </div>
    </div>
    <div id="platformer-menu" class="platformer-menu">
      <canvas id="entity-canvas"></canvas>
      <div class="controls-row">
        <button id="move-left-btn" class="control-btn" aria-label="Move Left">&#9664;</button>
        <input type="range" id="menu-slider" min="0" max="1000" value="0" />
        <button id="move-right-btn" class="control-btn" aria-label="Move Right">&#9654;</button>
        <button id="jump-btn" class="control-btn jump-btn" aria-label="Jump">&#9650; JUMP</button>
      </div>
      <div id="pixel-bubble" class="pixel-bubble" style="display:none">
        <span id="bubble-text"></span>
        <button id="bubble-open-btn">[ OPEN ]</button>
      </div>
    </div>
    <div class="content">
      <div class="canvas-wrapper" id="canvas-app">
        <div id="maze-pause-overlay" class="maze-pause-overlay" style="display: none;">
          <div class="pause-symbol">❚❚</div>
          <div class="pause-text">PAUSED</div>
        </div>
      </div>
    </div>
  </main>
  <a
    href="#"
    tabindex="0"
    class="button floating-menu__toggle-button"
    id="menu-toggle-button"
    aria-label="Toggle navigation menu"
  >
    <span class="floating-menu__toggle-button__expand">&gt;</span>
    <span class="floating-menu__toggle-button__collapse">&lt;</span>
  </a>
  <nav class="menu floating-menu" id="floating-menu">
    <div class="floating-menu__items">
      <a tabindex="-1" href={getAbsoluteUrl('/about')} class="red">About</a>
      <a tabindex="-1" href={getAbsoluteUrl('/portfolio')} class="pink">Portfolio</a>
      <a tabindex="-1" href={getAbsoluteUrl('/contact')} class="orange">Contact</a>
      <a tabindex="-1" href={getAbsoluteUrl('/resume')} class="aqua">CV</a>
    </div>
  </nav>
  <div id="transition-element" class="transition-element-wrapper">
    <div class="transition-element">
      <svg version="1.1" viewBox="0 0 14.817 16.933">
        <g transform="translate(-160.65 -46.987)">
          <path
            id="transition-element-path"
            d="m160.65 53.337v9.525h1.0583v1.0583h2.1167v-1.0583h1.0583v-1.0583h1.0583v1.0583h1.0583v1.0583h2.1167v-1.0583h1.0583v-1.0583h1.0583v1.0583h1.0583v1.0583h2.1167v-1.0583h1.0583v-9.525h-1.0583v-3.175h-1.0583v-1.0583h-1.0583v-1.0583h-2.1167v-1.0583h-4.2333v1.0583h-2.1167v1.0583h-1.0583v1.0583h-1.0583v3.175z"
          ></path>
        </g>
      </svg>
    </div>
  </div>
  <div class="subpages" id="content-wrapper">
    <slot />
  </div>
  <script>
    import '../main';
    import '../platformerMenu';
  </script>
</body>
