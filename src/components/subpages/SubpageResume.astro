---
import { getAbsoluteUrl } from '../../shared/utils/routing';
---
<div data-route="/resume" class="subpage subpage--resume">
  <article class="subpage__wrapper">
    <div class="subpage__header">
      <a href={getAbsoluteUrl('/')} class="subpage__close-button">X</a>
      <h2 class="subpage__title">Resume</h2>
    </div>
    <div class="subpage__content-wrapper">
      <div class="subpage__content cv-layout">
        <header class="cv-header">
          <h1>Tridibesh Sen</h1>
          <p class="cv-subtitle">Computer Science & Systems Engineer</p>
          <div class="cv-meta">
            <span>Kolkata, India</span> |
            <span><a href="https://www.linkedin.com/in/tridibesh-sen/" target="_blank">LinkedIn</a></span>
          </div>
          <div class="cv-download-container">
            <a
              href={getAbsoluteUrl('/images/Tridibesh_Sen_Resume.pdf')}
              download="Tridibesh_Sen_Resume.pdf"
              class="cv-download-btn"
            >
              DOWNLOAD CV (PDF)
            </a>
          </div>
        </header>

        <section class="cv-section">
          <h3>Summary</h3>
          <p>
            Passionate <b>B.Tech Computer Science Student</b> at UEM Kolkata with a dedicated focus on building scalable systems, optimizing backend APIs, and bridging the gap between hardware and software. Hands-on experience developing low-latency integrations and deploying machine learning models onto edge hardware.
          </p>
        </section>

        <section class="cv-section">
          <h3>Experience</h3>

          <div class="cv-item">
            <div class="cv-item-header">
              <h4 class="cv-company">Web Developer | Ignitia</h4>
              <span class="cv-duration">May 2026 – Present</span>
            </div>
            <ul>
              <li>Built and maintained responsive web apps using React.js, HTML5, CSS3, and JavaScript.</li>
              <li>Collaborated with design and backend teams to ship user-centric features across production modules.</li>
            </ul>
          </div>

          <div class="cv-item">
            <div class="cv-item-header">
              <h4 class="cv-company">AI/ML Intern | IEDC, UEM Kolkata</h4>
              <span class="cv-duration">May 2026 – Present</span>
            </div>
            <div class="cv-role">Dept. of CSE IoT, CS & BT</div>
            <ul>
              <li>Prototyped ML models and GenAI pipelines using Python, scikit-learn, and OpenAI APIs.</li>
              <li>Contributed to internal AI research and delivered knowledge-sharing sessions on generative AI.</li>
            </ul>
          </div>

          <div class="cv-item">
            <div class="cv-item-header">
              <h4 class="cv-company">Core Member | Microsoft Student Society, UEMK</h4>
              <span class="cv-duration">June 2026 – Present</span>
            </div>
            <ul>
              <li>Organised technical workshops on Azure, GitHub, and developer tools; mentored juniors in cloud and full-stack fundamentals.</li>
            </ul>
          </div>

          <div class="cv-item">
            <div class="cv-item-header">
              <h4 class="cv-company">Solution Challenge Participant | Google Developer Experts</h4>
              <span class="cv-duration">Mar 2026 – Apr 2026</span>
            </div>
            <div class="cv-role">Solution Challenge 2026</div>
            <ul>
              <li>Built and pitched a community-impact solution using Firebase, Google Cloud, and React in a 2-month sprint.</li>
            </ul>
          </div>
        </section>

        <section class="cv-section">
          <h3>Projects</h3>

          <div class="cv-item">
            <h4 class="cv-company">AI-Powered Data Analysis Platform</h4>
            <ul>
              <li>Full-stack web app integrating the OpenAI Assistant API for automated data analysis and insights from uploaded datasets.</li>
              <li><b>Stack:</b> React.js, Node.js, OpenAI API, Firebase.</li>
            </ul>
          </div>

          <div class="cv-item">
            <h4 class="cv-company">MERN Stack Portfolio & Blog</h4>
            <ul>
              <li>Personal portfolio with a dynamic blog module built on MongoDB, Express.js, React, and Node.js.</li>
              <li>Features a dark-mode UI, project showcases, and contact forms.</li>
            </ul>
          </div>

          <div class="cv-item">
            <h4 class="cv-company">Cybersecurity Awareness Web App</h4>
            <ul>
              <li>Interactive educational app covering phishing, encryption, and network security concepts.</li>
              <li>Developed as part of Cyber Security Fundamentals certification coursework.</li>
            </ul>
          </div>

          <div class="cv-item">
            <h4 class="cv-company">MySQL Data Engineering Pipeline</h4>
            <ul>
              <li>Designed normalised schemas and ETL pipelines in MySQL for structured data ingestion, transformation, and reporting.</li>
            </ul>
          </div>
        </section>

        <section class="cv-section">
          <h3>Skills</h3>
          <div class="cv-skills-grid">
            <span class="cv-skill-pill">JavaScript</span>
            <span class="cv-skill-pill">TypeScript</span>
            <span class="cv-skill-pill">Python</span>
            <span class="cv-skill-pill">C</span>
            <span class="cv-skill-pill">Bash/Shell</span>
            <span class="cv-skill-pill">React.js</span>
            <span class="cv-skill-pill">Next.js</span>
            <span class="cv-skill-pill">HTML5 / CSS3</span>
            <span class="cv-skill-pill">Tailwind CSS</span>
            <span class="cv-skill-pill">Node.js</span>
            <span class="cv-skill-pill">Express.js</span>
            <span class="cv-skill-pill">REST APIs</span>
            <span class="cv-skill-pill">Firebase</span>
            <span class="cv-skill-pill">MySQL</span>
            <span class="cv-skill-pill">MongoDB</span>
            <span class="cv-skill-pill">OpenAI API</span>
            <span class="cv-skill-pill">Generative AI</span>
            <span class="cv-skill-pill">Data Analysis</span>
            <span class="cv-skill-pill">Pandas</span>
            <span class="cv-skill-pill">scikit-learn</span>
            <span class="cv-skill-pill">Git / GitHub</span>
            <span class="cv-skill-pill">VS Code</span>
            <span class="cv-skill-pill">Figma</span>
            <span class="cv-skill-pill">Linux</span>
          </div>
        </section>

        <section class="cv-section">
          <h3>Education</h3>

          <div class="cv-item">
            <div class="cv-item-header">
              <h4 class="cv-school">B.Tech — Computer Science and Engineering</h4>
              <span class="cv-duration">July 2025 – July 2029</span>
            </div>
            <div class="cv-role">University of Engineering & Management (UEM), Kolkata</div>
            <ul>
              <li>Focused on AI, Data Analytics, and Full-Stack Web Development.</li>
            </ul>
          </div>

          <div class="cv-item">
            <div class="cv-item-header">
              <h4 class="cv-school">Higher Secondary (Class XII — Science)</h4>
              <span class="cv-duration">Apr 2023 – Apr 2025</span>
            </div>
            <div class="cv-role">GSMS Taki House, West Bengal, India</div>
          </div>
        </section>

        <section class="cv-section">
          <h3>Certifications</h3>
          <div class="cv-skills-grid">
            <span class="cv-skill-pill">GenAI for Data Analysis: OpenAI Assistant API</span>
            <span class="cv-skill-pill">MySQL for Data Engineering</span>
            <span class="cv-skill-pill">AI Tools Workshop</span>
            <span class="cv-skill-pill">Cyber Security Fundamentals</span>
            <span class="cv-skill-pill">Problem Solving Through Programming in C</span>
            <span class="cv-skill-pill">Generative AI for Web Developers</span>
          </div>
        </section>

        <section class="cv-section">
          <h3>Languages</h3>
          <div class="cv-skills-grid">
            <span class="cv-skill-pill">English (Full Professional)</span>
            <span class="cv-skill-pill">Bangla (Professional Working)</span>
            <span class="cv-skill-pill">Hindi (Professional Working)</span>
          </div>
        </section>
      </div>
    </div>
  </article>
</div>
